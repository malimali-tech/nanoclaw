# NanoClaw environment contract. Copy to .env and fill in; .env is gitignored.

# LLM provider selection. One of: openclaude | anthropic | open-agent-sdk
# - openclaude:     openclaude CLI + Gemini (default)
# - anthropic:      official @anthropic-ai/claude-code CLI (credentials via OneCLI)
# - open-agent-sdk: @codeany/open-agent-sdk in-process (OpenAI-compatible only)
NANOCLAW_LLM_PROVIDER=openclaude

# Unified LLM credentials — same vars regardless of provider.
# Required for: openclaude, open-agent-sdk. Ignored for: anthropic (uses OneCLI).
NANOCLAW_LLM_API_KEY=

# Optional. Defaults per provider:
# - openclaude:     gemini-3.1-pro-preview (alts: gemini-3.1-flash-lite)
# - open-agent-sdk: deepseek-chat (alts: deepseek-reasoner, gpt-4o, qwen-max)
# NANOCLAW_LLM_MODEL=

# Optional. Custom OpenAI-compatible endpoint. Used by open-agent-sdk only.
# NANOCLAW_LLM_BASE_URL=https://api.deepseek.com/v1

# Feishu / Lark channel
# App ID and App Secret from the Feishu/Lark developer console:
#   https://open.feishu.cn/app  (Feishu 国内)
#   https://open.larksuite.com/app  (Lark 国际)
# The channel auto-enables when both FEISHU_APP_ID and FEISHU_APP_SECRET are set.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# FEISHU_DOMAIN selects the SDK endpoint: "feishu" (default) for 国内版, "lark" for 国际版.
FEISHU_DOMAIN=feishu
